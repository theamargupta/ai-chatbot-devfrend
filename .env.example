# ===== Required =====

# Anthropic API key for Claude LLM
ANTHROPIC_API_KEY=sk-ant-...

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Your deployed app URL (required for production — used in embed codes, CORS, etc.)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# ===== Optional =====

# Resend API key (for escalation email notifications)
RESEND_API_KEY=re_...

# Set to 'false' to disable local embeddings (required on Vercel — native ONNX binaries unavailable)
EMBEDDINGS_ENABLED=true
